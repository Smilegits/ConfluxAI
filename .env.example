# Provider: openai or azure
LLM_PROVIDER=openai

# Reranker: llm (uses configured LLM) or crossencoder (local HuggingFace model)
RERANKER_TYPE=llm

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# ── Azure OpenAI (set LLM_PROVIDER=azure to use) ─────────────────────────────
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=rag_chatbot

# ── Web loader ────────────────────────────────────────────────────────────────
# Corp proxy: requests picks these up automatically
# HTTP_PROXY=http://user:pass@proxy:8080
# HTTPS_PROXY=http://user:pass@proxy:8080

# SSL: set false to bypass corp proxy SSL inspection (MITM), or point to corp CA cert
WEB_SSL_VERIFY=true
# REQUESTS_CA_BUNDLE=C:\certs\corp-ca.crt

# Playwright HTTP client (optional, no browser needed)
# Requires: pip install playwright && playwright install chromium
USE_PLAYWRIGHT_REQUESTS=false

# ── Confluence Integration ─────────────────────────────────────────────────────
# Enable/disable Confluence integration
CONFLUENCE_ENABLED=true

# Comma-separated list of Confluence space keys to sync (e.g., ENG,PRODUCT,DOCS)
CONFLUENCE_SPACES=ENG,PRODUCT

# Sync interval in minutes (how often to check for changes)
CONFLUENCE_SYNC_INTERVAL=5

# Path to SQLite tracking database (stores sync state and page metadata)
CONFLUENCE_TRACKING_DB=data/confluence_sync.db

# Rate limiting for Confluence API calls (calls per second)
CONFLUENCE_RATE_LIMIT=10
