# Provider: openai or azure
LLM_PROVIDER=openai

# Reranker: llm (uses configured LLM) or crossencoder (local HuggingFace model)
RERANKER_TYPE=llm

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# ── Azure OpenAI (set LLM_PROVIDER=azure to use) ─────────────────────────────
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=rag_chatbot

# ── Web loader ────────────────────────────────────────────────────────────────
# Use Playwright HTTP client instead of requests (no browser, works behind corp proxy)
# After enabling: pip install playwright && playwright install chromium
# Proxy: set HTTP_PROXY / HTTPS_PROXY here or in shell
USE_PLAYWRIGHT_REQUESTS=false
# HTTP_PROXY=http://user:pass@proxy:8080
# HTTPS_PROXY=http://user:pass@proxy:8080
